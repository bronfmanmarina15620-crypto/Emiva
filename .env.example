# Copy to .env.local and adjust. .env.local is gitignored.

# Items per session (default: 10). Dev override example: 3.
NEXT_PUBLIC_ITEMS_PER_SESSION=10

# Optional gate code shown before navigating to /parent. If unset,
# clicking "הורים" navigates directly. If set, an inline password input
# appears and only the matching value navigates. NOT real security
# (visible in client bundle); blocks accidental discovery only.
# NEXT_PUBLIC_PARENT_GATE_CODE=your_code_here
