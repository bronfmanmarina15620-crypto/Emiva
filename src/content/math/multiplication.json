  { "id": "mult-money-001", "skill": "multiplication", "difficulty": 1, "prompt": "קניתי 3 שקיות חטיף ב-2₪ כל אחת. כמה שילמתי?", "answer": 6, "operands": [3, 2], "op": "*", "context": "money", "explanation": "3 קבוצות של 2₪ זה כפול: 2+2+2 = 6₪." },
  { "id": "mult-money-002", "skill": "multiplication", "difficulty": 1, "prompt": "סבתא נתנה 4 מטבעות של 5₪. כמה כסף קיבלתי?", "answer": 20, "operands": [4, 5], "op": "*", "context": "money", "explanation": "5₪ זה חצי מ-10₪. 4×5 = חצי מ-4×10 = חצי מ-40 = 20₪." },
  { "id": "mult-money-003", "skill": "multiplication", "difficulty": 1, "prompt": "כרטיס למוזיאון עולה 10₪. כמה ישלמו 6 ילדות?", "answer": 60, "operands": [6, 10], "op": "*", "context": "money", "explanation": "להוסיף אפס: 6×10 זה 6 עם אפס בסוף = 60₪." },
  { "id": "mult-money-004", "skill": "multiplication", "difficulty": 1, "prompt": "בקיוסק סוכריות זוגיות, 2₪ לזוג. קניתי 7 זוגות. כמה?", "answer": 14, "operands": [7, 2], "op": "*", "context": "money", "explanation": "7 זוגות של 2₪. כפול של 7: 7+7 = 14₪." },
  { "id": "mult-money-005", "skill": "multiplication", "difficulty": 1, "prompt": "אני חוסכת 5₪ בכל שבוע. בעוד 8 שבועות, כמה אחסוך?", "answer": 40, "operands": [8, 5], "op": "*", "context": "money", "explanation": "5₪ הוא חצי מ-10₪. 8×5 = חצי מ-8×10 = חצי מ-80 = 40₪." },
  { "id": "mult-money-006", "skill": "multiplication", "difficulty": 1, "prompt": "9 חברות שילמו 10₪ כל אחת לסדנת אומנות. סה\"כ?", "answer": 90, "operands": [9, 10], "op": "*", "context": "money", "explanation": "להוסיף אפס: 9×10 = 90₪." },

